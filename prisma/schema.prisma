generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Problem {
  id                   String             @id @default(auto()) @map("_id") @db.ObjectId
  slug                 String             @unique
  title                String
  tagline              String
  excerpt              String
  summary              String
  description          String
  targetUser           String
  painPoint            String
  suggestedMvp         String
  demandSignalsSummary String
  riskNotes            String
  category             String
  industry             String?
  geographyFocus       String?
  companySize          String?
  recommendedSkill     SkillLevel
  projectTypes         ProjectType[]
  monetizationTypes    MonetizationType[]
  status               ProblemStatus      @default(DRAFT)
  buildTimeValue       Int
  buildTimeUnit        BuildTimeUnit
  difficultyScore      Int
  demandScore          Int
  monetizationScore    Int
  validationScore      Int
  editorialScore       Int
  featured             Boolean            @default(false)
  publishedAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  tagIds               String[]           @db.ObjectId
  stackIds             String[]           @db.ObjectId
  evidences            ProblemEvidence[]
  adminNotes           AdminNote[]
  tags                 ProblemTag[]       @relation("ProblemTags", fields: [tagIds], references: [id])
  stacks               ProblemStack[]     @relation("ProblemStacks", fields: [stackIds], references: [id])

  @@index([status, featured])
  @@index([category, recommendedSkill])
  @@index([slug, status])
}

model ProblemEvidence {
  id             String     @id @default(auto()) @map("_id") @db.ObjectId
  problemId      String     @db.ObjectId
  title          String
  summary        String
  sourceType     SourceType
  sourceName     String
  sourceUrl      String?
  snippet        String?
  signalStrength Int
  capturedAt     DateTime?
  createdAt      DateTime   @default(now())
  problem        Problem    @relation(fields: [problemId], references: [id])

  @@index([problemId, sourceType])
}

model ProblemTag {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  slug        String    @unique
  name        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  problemIds  String[]  @db.ObjectId
  problems    Problem[] @relation("ProblemTags", fields: [problemIds], references: [id])
}

model ProblemStack {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  slug        String    @unique
  name        String    @unique
  category    String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  problemIds  String[]  @db.ObjectId
  problems    Problem[] @relation("ProblemStacks", fields: [problemIds], references: [id])
}

model AdminNote {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  problemId  String    @db.ObjectId
  title      String
  body       String
  isInternal Boolean   @default(true)
  pinned     Boolean   @default(false)
  createdBy  String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  problem    Problem   @relation(fields: [problemId], references: [id])

  @@index([problemId, pinned])
}

model NewsletterSignup {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  email          String    @unique
  firstName      String?
  source         String?
  interests      String[]
  confirmedAt    DateTime?
  unsubscribedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([createdAt])
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum ProjectType {
  SAAS
  INTERNAL_TOOL
  MARKETPLACE
  AUTOMATION
  ANALYTICS
  DEVELOPER_TOOL
  MOBILE_APP
  SERVICE_BUSINESS_TOOL
}

enum MonetizationType {
  SUBSCRIPTION
  ONE_TIME_LICENSE
  USAGE_BASED
  LEAD_GEN
  AGENCY_UPSELL
  TRANSACTION_FEE
}

enum SourceType {
  INTERVIEW
  FORUM
  JOB_POSTING
  REVIEW_SITE
  SEARCH_TREND
  MARKET_REPORT
  SUPPORT_TICKET
  SOCIAL_POST
}

enum ProblemStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

enum BuildTimeUnit {
  DAYS
  WEEKS
  MONTHS
}
